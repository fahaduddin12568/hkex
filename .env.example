# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── Notes ───────────────────────────────────────────────────────────────────
# These values are injected at runtime in supabase-config.js
# In Netlify: Site Settings → Environment Variables → add both keys above
# The ANON key is safe to expose publicly (it's subject to Row Level Security)
